# Application files and folders
/tmp

# Composer dependencies
/vendor

# Editor settings
/.idea
/.claude/settings.local.json

###> symfony/framework-bundle ###
/.env.local
/.env.local.php
/.env.*.local
/public/bundles/
# Use /var/* (not /var/) so nested negation patterns work — git won't
# descend into a fully-ignored directory to check for child exceptions.
/var/*
# Pre-built Tailwind CSS — production host cannot run the Tailwind CLI binary.
# Three lines are needed: un-ignore parent dir, re-ignore its contents, then exempt the files.
!/var/tailwind/
/var/tailwind/*
!/var/tailwind/*.built.css
/vendor/
###< symfony/framework-bundle ###

# Symfony Flex auto-generated files
/config/reference.php
/config/preload.php

