{% extends 'base.html.twig' %}

{% block title %}Edit {{ credential.displayLabel }} — Contacts Sync{% endblock %}

{% block body %}
<div class="mb-8">
    <nav class="flex" aria-label="Breadcrumb">
        <ol role="list" class="flex items-center space-x-4">
            <li>
                <a href="{{ path('app_credentials_index') }}" class="text-sm font-medium text-gray-500 hover:text-gray-700">Credentials</a>
            </li>
            <li>
                <div class="flex items-center">
                    <svg class="h-5 w-5 flex-shrink-0 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                    </svg>
                    <span class="ml-4 text-sm font-medium text-gray-900">Edit {{ credential.displayLabel }}</span>
                </div>
            </li>
        </ol>
    </nav>
    <h1 class="mt-4 text-2xl font-bold text-gray-900">Edit {{ provider.displayName }}: {{ credential.displayLabel }}</h1>
</div>

<div class="max-w-3xl">
    <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            {% include 'provider_credential/_form.html.twig' with { button_label: 'Update Credential' } %}
        </div>
    </div>
</div>
{% endblock %}
