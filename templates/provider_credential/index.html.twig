{% extends 'base.html.twig' %}

{% block title %}Provider Credentials — Contacts Sync{% endblock %}

{% block body %}
<div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Provider Credentials</h1>
        <p class="mt-1 text-sm text-gray-500">Manage API credentials for sync sources and destinations.</p>
    </div>
    <div class="mt-4 sm:mt-0 flex gap-x-2">
        {% for name, provider in providers %}
            <a href="{{ path('app_credentials_new', { providerName: name }) }}"
               class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors">
                <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" />
                </svg>
                Add {{ provider.displayName }}
            </a>
        {% endfor %}
    </div>
</div>

{% if credentials|length > 0 %}
    <div class="overflow-hidden bg-white shadow ring-1 ring-black/5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Label</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Provider</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Created</th>
                    <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
                {% for credential in credentials %}
                    {% set provider = providers[credential.providerName] ?? null %}
                    {% set credArray = credential.credentialsArray %}
                    {% set isOAuth = credential.providerName in oauth_providers %}
                    {% set isConnected = credArray.token is defined and credArray.token is not null %}
                    <tr class="hover:bg-gray-50">
                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6">
                            {{ credential.displayLabel }}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                            {{ provider ? provider.displayName : credential.providerName }}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm">
                            {% if isOAuth %}
                                {% if isConnected %}
                                    <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                                        <svg class="-ml-0.5 mr-1 h-2 w-2 text-green-400" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" /></svg>
                                        Connected
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">
                                        <svg class="-ml-0.5 mr-1 h-2 w-2 text-yellow-400" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" /></svg>
                                        Not Connected
                                    </span>
                                {% endif %}
                            {% else %}
                                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                                    <svg class="-ml-0.5 mr-1 h-2 w-2 text-green-400" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" /></svg>
                                    Configured
                                </span>
                            {% endif %}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                            {{ credential.createdAt|date('M j, Y') }}
                        </td>
                        <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                            <div class="flex items-center justify-end gap-x-3">
                                {% if isOAuth %}
                                    {% if isConnected %}
                                        <form action="{{ path('app_credentials_oauth_disconnect', { id: credential.id }) }}" method="post" class="inline"
                                              data-controller="confirm"
                                              data-confirm-message-value="Are you sure you want to disconnect? Syncing will stop working until you reconnect.">
                                            <input type="hidden" name="_token" value="{{ csrf_token('oauth-disconnect-' ~ credential.id) }}">
                                            <button type="submit" class="text-orange-600 hover:text-orange-900" title="Disconnect OAuth">
                                                Disconnect
                                            </button>
                                        </form>
                                    {% else %}
                                        <a href="{{ path('app_credentials_oauth_connect', { id: credential.id }) }}" class="text-indigo-600 hover:text-indigo-900">
                                            Connect
                                        </a>
                                    {% endif %}
                                {% endif %}
                                <a href="{{ path('app_credentials_edit', { id: credential.id }) }}" class="text-indigo-600 hover:text-indigo-900" title="Edit">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                                    </svg>
                                </a>
                                <form action="{{ path('app_credentials_delete', { id: credential.id }) }}" method="post" class="inline"
                                      data-controller="confirm"
                                      data-confirm-message-value="Are you sure you want to delete this credential? Sync lists using it will stop working.">
                                    <input type="hidden" name="_method" value="DELETE">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-credential-' ~ credential.id) }}">
                                    <button type="submit" class="text-red-600 hover:text-red-900" title="Delete">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% else %}
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">No credentials</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by adding a provider credential.</p>
        <div class="mt-6 flex justify-center gap-x-2">
            {% for name, provider in providers %}
                <a href="{{ path('app_credentials_new', { providerName: name }) }}"
                   class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors">
                    <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" />
                    </svg>
                    Add {{ provider.displayName }}
                </a>
            {% endfor %}
        </div>
    </div>
{% endif %}
{% endblock %}
