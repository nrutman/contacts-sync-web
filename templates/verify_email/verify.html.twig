{% extends 'base_public.html.twig' %}

{% block title %}Set Your Password — Contacts Sync{% endblock %}

{% block body %}
<div class="bg-white rounded-lg shadow-md p-8">
    <h2 class="text-xl font-bold text-center text-gray-900 mb-2">Set Your Password</h2>
    <p class="text-sm text-center text-gray-500 mb-6">
        Welcome, <strong>{{ user.firstName }}</strong>! Choose a password to complete your account setup.
    </p>

    <div class="mb-6 rounded-md bg-gray-50 border border-gray-200 p-3">
        <div class="flex items-center gap-x-2">
            <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <span class="text-sm text-gray-600">{{ user.email }}</span>
        </div>
    </div>

    {{ form_start(form, { action: path('app_verify_email_complete'), attr: { class: 'space-y-4' } }) }}
        {{ form_errors(form) }}

        <div>
            {{ form_label(form.plainPassword.first, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.plainPassword.first, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm placeholder-gray-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 sm:text-sm' } }) }}
            {{ form_errors(form.plainPassword.first, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
        </div>

        <div>
            {{ form_label(form.plainPassword.second, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
            {{ form_widget(form.plainPassword.second, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm placeholder-gray-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 sm:text-sm' } }) }}
            {{ form_errors(form.plainPassword.second, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
        </div>

        {{ form_widget(form.token) }}

        <div class="pt-2">
            <button type="submit"
                    class="w-full flex justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors">
                Set Password &amp; Activate Account
            </button>
        </div>
    {{ form_end(form) }}

    <p class="mt-4 text-xs text-center text-gray-400">Your password must be at least 8 characters long.</p>
</div>
{% endblock %}
