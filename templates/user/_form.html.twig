{{ form_start(form, { attr: { class: 'space-y-6' } }) }}
    {% if form.email is defined %}
        <div>
            {{ form_label(form.email, null, { label_attr: { class: 'block text-sm font-medium text-gray-700' } }) }}
            <div class="mt-1">
                {{ form_widget(form.email, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm placeholder-gray-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 sm:text-sm' } }) }}
            </div>
            {{ form_errors(form.email, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
            {% if form.email.vars.help %}
                <p class="mt-1 text-sm text-gray-500">{{ form.email.vars.help }}</p>
            {% endif %}
        </div>
    {% endif %}

    {% if is_edit is defined and is_edit and user is defined %}
        <div>
            <label class="block text-sm font-medium text-gray-700">Email Address</label>
            <div class="mt-1">
                <input type="email" value="{{ user.email }}" disabled readonly
                       class="block w-full rounded-md border border-gray-200 bg-gray-50 px-3 py-2 text-gray-500 shadow-sm sm:text-sm cursor-not-allowed">
            </div>
            <p class="mt-1 text-xs text-gray-400">Email cannot be changed after creation.</p>
        </div>
    {% endif %}

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
            {{ form_label(form.firstName, null, { label_attr: { class: 'block text-sm font-medium text-gray-700' } }) }}
            <div class="mt-1">
                {{ form_widget(form.firstName, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm placeholder-gray-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 sm:text-sm' } }) }}
            </div>
            {{ form_errors(form.firstName, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
        </div>

        <div>
            {{ form_label(form.lastName, null, { label_attr: { class: 'block text-sm font-medium text-gray-700' } }) }}
            <div class="mt-1">
                {{ form_widget(form.lastName, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm placeholder-gray-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 sm:text-sm' } }) }}
            </div>
            {{ form_errors(form.lastName, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
        </div>
    </div>

    <fieldset>
        <legend class="block text-sm font-medium text-gray-700">{{ form_label(form.roles) }}</legend>
        {% if form.roles.vars.help %}
            <p class="mt-1 text-sm text-gray-500">{{ form.roles.vars.help }}</p>
        {% endif %}
        <div class="mt-2 space-y-2">
            {% for child in form.roles %}
                <div class="flex items-center gap-x-3">
                    {{ form_widget(child, { attr: { class: 'h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500' } }) }}
                    {{ form_label(child, null, { label_attr: { class: 'text-sm text-gray-700' } }) }}
                </div>
            {% endfor %}
        </div>
        {{ form_errors(form.roles, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
    </fieldset>

    <div class="flex items-center justify-end gap-x-4 border-t border-gray-200 pt-6">
        <a href="{{ path('app_user_index') }}" class="text-sm font-semibold text-gray-700 hover:text-gray-900">Cancel</a>
        <button type="submit"
                class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors">
            {{ button_label|default('Save') }}
        </button>
    </div>
{{ form_end(form) }}
