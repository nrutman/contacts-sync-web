{% extends 'base.html.twig' %}

{% block title %}New Contact — Contacts Sync{% endblock %}

{% block body %}
<div class="mb-8">
    <twig:Breadcrumb>
        <twig:Breadcrumb:List>
            <twig:Breadcrumb:Item>
                <twig:Breadcrumb:Link href="{{ path('app_contact_index') }}">Manual Contacts</twig:Breadcrumb:Link>
            </twig:Breadcrumb:Item>
            <twig:Breadcrumb:Separator />
            <twig:Breadcrumb:Item>
                <twig:Breadcrumb:Page>New</twig:Breadcrumb:Page>
            </twig:Breadcrumb:Item>
        </twig:Breadcrumb:List>
    </twig:Breadcrumb>
    <h1 class="mt-4 text-2xl font-bold text-foreground">New Manual Contact</h1>
    <p class="mt-1 text-sm text-muted-foreground">Add a contact that will be merged into selected sync lists alongside synced contacts.</p>
</div>

<div class="max-w-2xl">
    <twig:Card class="p-6">
        {% include 'manual_contact/_form.html.twig' with { button_label: 'Create Contact' } %}
    </twig:Card>
</div>
{% endblock %}
