{% extends 'base.html.twig' %}

{% block title %}History: {{ sync_list.name }} — Contacts Sync{% endblock %}

{% block body %}
<div class="mb-8">
    <nav class="flex" aria-label="Breadcrumb">
        <ol role="list" class="flex items-center space-x-4">
            <li>
                <a href="{{ path('app_sync_list_index') }}" class="text-sm font-medium text-gray-500 hover:text-gray-700">Sync Lists</a>
            </li>
            <li>
                <div class="flex items-center">
                    <svg class="h-5 w-5 flex-shrink-0 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                    </svg>
                    <span class="ml-4 text-sm font-medium text-gray-500">{{ sync_list.name }}</span>
                </div>
            </li>
            <li>
                <div class="flex items-center">
                    <svg class="h-5 w-5 flex-shrink-0 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                    </svg>
                    <span class="ml-4 text-sm font-medium text-gray-900">History</span>
                </div>
            </li>
        </ol>
    </nav>
    <div class="mt-4 sm:flex sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Sync History</h1>
            <p class="mt-1 text-sm text-gray-500">
                Sync runs for <strong>{{ sync_list.name }}</strong>
                —
                {% if sync_list.isEnabled %}
                    <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-800">Enabled</span>
                {% else %}
                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-800">Disabled</span>
                {% endif %}
                {% if sync_list.cronExpression %}
                    — Schedule: <code class="rounded bg-gray-100 px-1.5 py-0.5 text-xs font-mono">{{ sync_list.cronExpression }}</code>
                {% endif %}
            </p>
        </div>
        <div class="mt-4 sm:mt-0 flex gap-x-3">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_sync_list_edit', { id: sync_list.id }) }}"
                   class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors">
                    <svg class="-ml-0.5 mr-1.5 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                    </svg>
                    Edit List
                </a>
            {% endif %}
        </div>
    </div>
</div>

{% if sync_runs|length > 0 %}
    <div class="overflow-hidden bg-white shadow ring-1 ring-black/5 sm:rounded-lg">
        <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Date</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Trigger</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Source</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Destination</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Added</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Removed</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Duration</th>
                    <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6"><span class="sr-only">View</span></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
                {% for run in sync_runs %}
                    <tr class="hover:bg-gray-50">
                        <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm text-gray-900 sm:pl-6" title="{{ run.createdAt|date('Y-m-d H:i:s T') }}">
                            {{ run.createdAt|date('M j, Y g:ia') }}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                                {% if run.triggeredBy == 'manual' %}bg-blue-100 text-blue-700
                                {% elseif run.triggeredBy == 'schedule' %}bg-purple-100 text-purple-700
                                {% elseif run.triggeredBy == 'cli' %}bg-gray-100 text-gray-700
                                {% else %}bg-gray-100 text-gray-700{% endif %}">
                                {{ run.triggeredBy|capitalize }}
                            </span>
                            {% if run.triggeredByUser %}
                                <span class="ml-1 text-xs text-gray-400">by {{ run.triggeredByUser.fullName }}</span>
                            {% endif %}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm">
                            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                                {% if run.status == 'success' %}bg-green-100 text-green-800
                                {% elseif run.status == 'failed' %}bg-red-100 text-red-800
                                {% elseif run.status == 'running' %}bg-yellow-100 text-yellow-800
                                {% else %}bg-gray-100 text-gray-800{% endif %}">
                                {{ run.status|capitalize }}
                            </span>
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                            {{ run.sourceCount ?? '—' }}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                            {{ run.destinationCount ?? '—' }}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm">
                            {% if run.addedCount is not null %}
                                <span class="{% if run.addedCount > 0 %}text-green-600 font-medium{% else %}text-gray-500{% endif %}">
                                    +{{ run.addedCount }}
                                </span>
                            {% else %}
                                <span class="text-gray-400">—</span>
                            {% endif %}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm">
                            {% if run.removedCount is not null %}
                                <span class="{% if run.removedCount > 0 %}text-red-600 font-medium{% else %}text-gray-500{% endif %}">
                                    -{{ run.removedCount }}
                                </span>
                            {% else %}
                                <span class="text-gray-400">—</span>
                            {% endif %}
                        </td>
                        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                            {% if run.durationSeconds is not null %}
                                {{ run.durationSeconds|number_format(1) }}s
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                            <a href="{{ path('app_history_show', { id: run.id }) }}" class="text-indigo-600 hover:text-indigo-900">View</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if page > 1 or has_more %}
        <nav class="mt-6 flex items-center justify-between" aria-label="Pagination">
            <div class="flex flex-1 justify-between sm:justify-end gap-x-3">
                {% if page > 1 %}
                    <a href="{{ path('app_sync_list_history', { id: sync_list.id, page: page - 1 }) }}"
                       class="relative inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors">
                        <svg class="-ml-0.5 mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                        </svg>
                        Previous
                    </a>
                {% endif %}
                {% if has_more %}
                    <a href="{{ path('app_sync_list_history', { id: sync_list.id, page: page + 1 }) }}"
                       class="relative inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors">
                        Next
                        <svg class="-mr-0.5 ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                        </svg>
                    </a>
                {% endif %}
            </div>
        </nav>
    {% endif %}
{% else %}
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">No sync history</h3>
        <p class="mt-1 text-sm text-gray-500">This list has not been synced yet. Sync runs will appear here after a sync is triggered.</p>
    </div>
{% endif %}
{% endblock %}
