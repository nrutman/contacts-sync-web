{% extends 'base.html.twig' %}

{% block title %}Sync Lists — Contacts Sync{% endblock %}

{% block body %}
<div {% if sync_lists|length > 0 %}
     data-controller="bulk-actions"
     data-bulk-actions-csrf-token-value="{{ csrf_token('bulk-actions') }}"
     data-bulk-actions-sync-csrf-token-value="{{ csrf_token('sync-run-all') }}"
{% endif %}>

<div class="sm:flex sm:items-center sm:justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-foreground">Sync Lists</h1>
        <p class="mt-1 text-sm text-muted-foreground">Manage sync configurations between source and destination providers.</p>
    </div>
    <div class="mt-4 sm:mt-0 flex items-center gap-4">
        {% if sync_lists|length > 0 and is_granted('ROLE_ADMIN') %}
            <div data-bulk-actions-target="toolbar" class="hidden flex items-center gap-3">
                <span data-bulk-actions-target="selectedCount" class="text-sm text-muted-foreground whitespace-nowrap"></span>
                <div class="relative">
                    <twig:ButtonGroup>
                        <twig:Button data-action="click->bulk-actions#syncSelected">
                            <twig:ux:icon name="lucide:play" class="size-4" />
                            Sync Selected
                        </twig:Button>
                        <twig:ButtonGroup:Separator />
                        <twig:Button size="icon" data-action="click->bulk-actions#toggleDropdown" aria-label="More bulk actions">
                            <twig:ux:icon name="lucide:chevron-down" class="size-4" />
                        </twig:Button>
                    </twig:ButtonGroup>
                    <div data-bulk-actions-target="dropdown"
                         class="hidden absolute right-0 top-full mt-1.5 w-52 rounded-lg border border-border bg-popover p-1.5 shadow-lg z-50">
                        <button type="button"
                                data-action="click->bulk-actions#activate"
                                class="flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-sm hover:bg-accent hover:text-accent-foreground">
                            <twig:ux:icon name="lucide:circle-play" class="size-4 text-muted-foreground" />
                            Activate
                        </button>
                        <button type="button"
                                data-action="click->bulk-actions#deactivate"
                                class="flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-sm hover:bg-accent hover:text-accent-foreground">
                            <twig:ux:icon name="lucide:circle-pause" class="size-4 text-muted-foreground" />
                            Deactivate
                        </button>
                        <button type="button"
                                data-action="click->bulk-actions#openSchedule"
                                class="flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-sm hover:bg-accent hover:text-accent-foreground">
                            <twig:ux:icon name="lucide:calendar" class="size-4 text-muted-foreground" />
                            Set Schedule
                        </button>
                    </div>
                </div>
            </div>
        {% endif %}
        {% if enabledSyncLists|length > 0 %}
            <div data-controller="sync-all"
                 data-sync-all-lists-value="{{ enabledSyncLists|map(l => { id: l.id, name: l.name })|json_encode|e('html_attr') }}"
                 data-sync-all-csrf-token-value="{{ csrf_token('sync-run-all') }}">
                <form action="{{ path('app_sync_run_all') }}" method="post" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('sync-run-all') }}">
                    <twig:Button type="submit" data-action="click->sync-all#submit">
                        <twig:ux:icon name="lucide:play" class="size-4" />
                        Sync All
                    </twig:Button>
                </form>

                {{ include('_sync_all_dialog.html.twig') }}
            </div>
        {% endif %}
        {% if is_granted('ROLE_ADMIN') %}
            <twig:Button as="a" href="{{ path('app_sync_list_new') }}">
                <twig:ux:icon name="lucide:plus" class="size-4" />
                New Sync List
            </twig:Button>
        {% endif %}
    </div>
</div>

{% if sync_lists|length > 0 %}
    <twig:Card>
        <twig:Table>
            <twig:Table:Header>
                <twig:Table:Row>
                    {% if is_granted('ROLE_ADMIN') %}
                        <twig:Table:Head class="w-10">
                            <input type="checkbox"
                                   data-bulk-actions-target="selectAll"
                                   data-action="change->bulk-actions#toggleAll"
                                   class="rounded border-input" />
                        </twig:Table:Head>
                    {% endif %}
                    <twig:Table:Head>Name</twig:Table:Head>
                    <twig:Table:Head>Status</twig:Table:Head>
                    <twig:Table:Head>Schedule</twig:Table:Head>
                    <twig:Table:Head>Contacts</twig:Table:Head>
                    <twig:Table:Head>Last Sync</twig:Table:Head>
                    <twig:Table:Head class="text-right"><span class="sr-only">Actions</span></twig:Table:Head>
                </twig:Table:Row>
            </twig:Table:Header>
            <twig:Table:Body>
                {% for list in sync_lists %}
                    <twig:Table:Row>
                        {% if is_granted('ROLE_ADMIN') %}
                            <twig:Table:Cell>
                                <input type="checkbox"
                                       value="{{ list.id }}"
                                       data-list-name="{{ list.name }}"
                                       data-bulk-actions-target="rowCheckbox"
                                       data-action="change->bulk-actions#toggleRow"
                                       class="rounded border-input" />
                            </twig:Table:Cell>
                        {% endif %}
                        <twig:Table:Cell class="font-medium">
                            <a href="{{ path('app_sync_list_history', { id: list.id }) }}" class="text-primary hover:underline">
                                {{ list.name }}
                            </a>
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            {% if list.isEnabled %}
                                <twig:Badge variant="success">Enabled</twig:Badge>
                            {% else %}
                                <twig:Badge variant="destructive">Disabled</twig:Badge>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            {% if list.cronExpression %}
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">{{ list.cronExpression }}</code>
                            {% else %}
                                <span class="text-muted-foreground">Manual only</span>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            {% set listId = list.id ~ '' %}
                            {% if contactCounts[listId] is defined and contactCounts[listId] is not null %}
                                <a href="{{ path('app_sync_list_contacts', { id: list.id }) }}" class="text-primary hover:underline">
                                    {{ contactCounts[listId] }} contacts
                                </a>
                            {% endif %}
                            {% if list.manualContacts|length > 0 %}
                                <span class="text-muted-foreground text-xs">({{ list.manualContacts|length }} manual)</span>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell>
                            {% if list.syncRuns|length > 0 %}
                                {% set lastRun = list.syncRuns|first %}
                                <twig:Badge variant="{{ lastRun.status == 'success' ? 'success-outline' : (lastRun.status == 'failed' ? 'destructive-outline' : (lastRun.status == 'running' ? 'secondary' : 'outline')) }}">
                                    {{ lastRun.status|capitalize }}
                                </twig:Badge>
                                <span class="ml-1 text-xs text-muted-foreground"
                                      data-controller="timezone"
                                      data-timezone-datetime-value="{{ lastRun.createdAt|date('c') }}"
                                      title="{{ lastRun.createdAt|date('Y-m-d H:i:s T') }}">
                                    {{ lastRun.createdAt|date('M j, g:ia') }}
                                </span>
                            {% else %}
                                <span class="text-muted-foreground">Never</span>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-right">
                            <div class="flex items-center justify-end gap-x-1">
                                <form action="{{ path('app_sync_list_run', { id: list.id }) }}" method="post" class="inline"
                                      data-controller="sync-button">
                                    <input type="hidden" name="_token" value="{{ csrf_token('sync-list-' ~ list.id) }}">
                                    <twig:Button type="submit" variant="ghost" size="icon-sm"
                                            data-sync-button-target="button"
                                            data-action="click->sync-button#submit"
                                            title="Sync Now">
                                        <twig:ux:icon data-sync-button-target="label" name="lucide:play" class="size-4" />
                                        <twig:Spinner data-sync-button-target="spinner" class="hidden size-4" />
                                    </twig:Button>
                                </form>
                                <twig:Button as="a" href="{{ path('app_sync_list_history', { id: list.id }) }}" variant="ghost" size="icon-sm" title="History">
                                    <twig:ux:icon name="lucide:history" class="size-4" />
                                </twig:Button>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <form action="{{ path('app_sync_list_toggle', { id: list.id }) }}" method="post" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle-sync-list-' ~ list.id) }}">
                                        <twig:Button type="submit" variant="ghost" size="icon-sm" title="{{ list.isEnabled ? 'Disable' : 'Enable' }}">
                                            {% if list.isEnabled %}
                                                <twig:ux:icon name="lucide:circle-pause" class="size-4" />
                                            {% else %}
                                                <twig:ux:icon name="lucide:circle-play" class="size-4" />
                                            {% endif %}
                                        </twig:Button>
                                    </form>
                                    <twig:Button as="a" href="{{ path('app_sync_list_edit', { id: list.id }) }}" variant="ghost" size="icon-sm" title="Edit">
                                        <twig:ux:icon name="lucide:pencil" class="size-4" />
                                    </twig:Button>
                                    <twig:AlertDialog id="delete-list-{{ list.id }}">
                                        <twig:AlertDialog:Trigger>
                                            <twig:Button variant="ghost" size="icon-sm" title="Delete" class="text-destructive hover:text-destructive" {{ ...trigger_attrs }}>
                                                <twig:ux:icon name="lucide:trash-2" class="size-4" />
                                            </twig:Button>
                                        </twig:AlertDialog:Trigger>
                                        <twig:AlertDialog:Content>
                                            <twig:AlertDialog:Header>
                                                <twig:AlertDialog:Title>Delete sync list</twig:AlertDialog:Title>
                                                <twig:AlertDialog:Description>
                                                    Are you sure you want to delete "{{ list.name }}"? This will also delete all associated sync history. This action cannot be undone.
                                                </twig:AlertDialog:Description>
                                            </twig:AlertDialog:Header>
                                            <twig:AlertDialog:Footer>
                                                <twig:AlertDialog:Cancel>Cancel</twig:AlertDialog:Cancel>
                                                <form action="{{ path('app_sync_list_delete', { id: list.id }) }}" method="post" class="inline">
                                                    <input type="hidden" name="_method" value="DELETE">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-sync-list-' ~ list.id) }}">
                                                    <twig:AlertDialog:Action variant="destructive" type="submit">Delete</twig:AlertDialog:Action>
                                                </form>
                                            </twig:AlertDialog:Footer>
                                        </twig:AlertDialog:Content>
                                    </twig:AlertDialog>
                                {% endif %}
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </twig:Card>

    {% if is_granted('ROLE_ADMIN') %}
        {% include 'sync_list/_bulk_schedule_dialog.html.twig' %}
        {% include 'sync_list/_bulk_sync_dialog.html.twig' %}
    {% endif %}
{% else %}
    <div class="rounded-lg border-2 border-dashed border-border p-12 text-center">
        <twig:ux:icon name="lucide:list" class="mx-auto h-12 w-12 text-muted-foreground" />
        <h3 class="mt-2 text-sm font-semibold text-foreground">No sync lists</h3>
        <p class="mt-1 text-sm text-muted-foreground">Get started by creating your first sync list.</p>
        {% if is_granted('ROLE_ADMIN') %}
            <div class="mt-6">
                <twig:Button as="a" href="{{ path('app_sync_list_new') }}">
                    <twig:ux:icon name="lucide:plus" class="size-4" />
                    New Sync List
                </twig:Button>
            </div>
        {% endif %}
    </div>
{% endif %}

</div>
{% endblock %}
