{{ form_start(form, { attr: { class: 'space-y-6' } }) }}
    <div>
        {{ form_label(form.name, null, { label_attr: { class: 'block text-sm font-medium text-gray-700' } }) }}
        <div class="mt-1">
            {{ form_widget(form.name, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm placeholder-gray-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 sm:text-sm' } }) }}
        </div>
        {{ form_errors(form.name, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
        {% if form.name.vars.help %}
            <p class="mt-1 text-sm text-gray-500">{{ form.name.vars.help }}</p>
        {% endif %}
    </div>

    <div>
        {{ form_label(form.cronExpression, null, { label_attr: { class: 'block text-sm font-medium text-gray-700' } }) }}
        <div class="mt-1">
            {{ form_widget(form.cronExpression, { attr: { class: 'block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm placeholder-gray-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 sm:text-sm font-mono' } }) }}
        </div>
        {{ form_errors(form.cronExpression, { attr: { class: 'mt-1 text-sm text-red-600' } }) }}
        {% if form.cronExpression.vars.help %}
            <p class="mt-1 text-sm text-gray-500">{{ form.cronExpression.vars.help }}</p>
        {% endif %}
    </div>

    <div class="flex items-center gap-x-3">
        {{ form_widget(form.isEnabled, { attr: { class: 'h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500' } }) }}
        {{ form_label(form.isEnabled, null, { label_attr: { class: 'text-sm font-medium text-gray-700' } }) }}
        {% if form.isEnabled.vars.help %}
            <p class="text-sm text-gray-500">{{ form.isEnabled.vars.help }}</p>
        {% endif %}
    </div>

    <div class="flex items-center justify-end gap-x-4 border-t border-gray-200 pt-6">
        <a href="{{ path('app_sync_list_index') }}" class="text-sm font-semibold text-gray-700 hover:text-gray-900">Cancel</a>
        <button type="submit"
                class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors">
            {{ button_label|default('Save') }}
        </button>
    </div>
{{ form_end(form) }}
