{{ form_start(form, { attr: { class: 'space-y-6' } }) }}
    {{ form_row(form.name) }}

    {# Source Configuration #}
    <twig:Separator />
    <div class="space-y-4">
        <div>
            <h3 class="text-base font-semibold text-foreground">Source</h3>
            <p class="mt-1 text-sm text-muted-foreground">Where contacts are read from.</p>
        </div>
        {{ form_row(form.sourceCredential) }}
        {{ form_row(form.sourceListIdentifier) }}
    </div>

    {# Destination Configuration #}
    <twig:Separator />
    <div class="space-y-4">
        <div>
            <h3 class="text-base font-semibold text-foreground">Destination</h3>
            <p class="mt-1 text-sm text-muted-foreground">Where contacts are synced to.</p>
        </div>
        {{ form_row(form.destinationCredential) }}
        {{ form_row(form.destinationListIdentifier) }}
    </div>

    {# Schedule & Status #}
    <twig:Separator />
    <div class="space-y-4">
        <h3 class="text-base font-semibold text-foreground">Schedule</h3>

        <div data-controller="schedule-picker" data-schedule-picker-cron-value="{{ form.cronExpression.vars.value|default('') }}">
            {{ form_widget(form.cronExpression, { attr: { 'data-schedule-picker-target': 'cronInput', class: 'hidden' } }) }}
            {{ form_errors(form.cronExpression) }}

            <twig:Field>
                <twig:Field:Label>Frequency</twig:Field:Label>
                <twig:Field:Content>
                    <twig:Select data-schedule-picker-target="frequency" data-action="schedule-picker#frequencyChanged">
                        <option value="manual">Manual (no schedule)</option>
                        <option value="every30">Every 30 minutes</option>
                        <option value="hourly">Hourly</option>
                        <option value="daily">Daily</option>
                        <option value="weekly">Weekly</option>
                        <option value="custom">Custom</option>
                    </twig:Select>
                </twig:Field:Content>
            </twig:Field>

            <div data-schedule-picker-target="timeFields" class="mt-3 hidden">
                <twig:Field>
                    <twig:Field:Label>Time</twig:Field:Label>
                    <twig:Field:Content>
                        <div class="flex items-center gap-2">
                            <twig:Select data-schedule-picker-target="hourSelect" data-action="schedule-picker#updateCron" class="w-auto">
                                {% for h in 0..23 %}
                                    <option value="{{ h }}">{{ h < 10 ? '0' ~ h : h }}</option>
                                {% endfor %}
                            </twig:Select>
                            <span class="text-muted-foreground font-medium">:</span>
                            <twig:Select data-schedule-picker-target="minuteSelect" data-action="schedule-picker#updateCron" class="w-auto">
                                {% for m in range(0, 55, 5) %}
                                    <option value="{{ m }}">{{ m < 10 ? '0' ~ m : m }}</option>
                                {% endfor %}
                            </twig:Select>
                        </div>
                    </twig:Field:Content>
                </twig:Field>
            </div>

            <div data-schedule-picker-target="dayField" class="mt-3 hidden">
                <twig:Field>
                    <twig:Field:Label>Day of week</twig:Field:Label>
                    <twig:Field:Content>
                        <twig:Select data-schedule-picker-target="daySelect" data-action="schedule-picker#updateCron">
                            <option value="0">Sunday</option>
                            <option value="1">Monday</option>
                            <option value="2">Tuesday</option>
                            <option value="3">Wednesday</option>
                            <option value="4">Thursday</option>
                            <option value="5">Friday</option>
                            <option value="6">Saturday</option>
                        </twig:Select>
                    </twig:Field:Content>
                </twig:Field>
            </div>

            <div data-schedule-picker-target="customField" class="mt-3 hidden">
                <twig:Field>
                    <twig:Field:Label>Cron expression</twig:Field:Label>
                    <twig:Field:Content>
                        <twig:Input type="text"
                               data-schedule-picker-target="customInput"
                               data-action="input->schedule-picker#updateCron"
                               placeholder="e.g. */15 * * * *"
                               class="font-mono" />
                    </twig:Field:Content>
                </twig:Field>
            </div>

            <p data-schedule-picker-target="preview" class="mt-2 text-sm text-muted-foreground"></p>
        </div>

        {{ form_row(form.isEnabled) }}
    </div>

    <twig:Separator />
    <div class="flex items-center justify-end gap-x-4">
        <twig:Button as="a" href="{{ path('app_sync_list_index') }}" variant="outline">Cancel</twig:Button>
        <twig:Button type="submit">{{ button_label|default('Save') }}</twig:Button>
    </div>
{{ form_end(form) }}
