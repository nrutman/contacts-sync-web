{% extends 'base.html.twig' %}

{% block title %}Contacts: {{ sync_list.name }} — Contacts Sync{% endblock %}

{% block body %}
<div class="mb-8">
    <twig:Breadcrumb>
        <twig:Breadcrumb:List>
            <twig:Breadcrumb:Item>
                <twig:Breadcrumb:Link href="{{ path('app_sync_list_index') }}">Sync Lists</twig:Breadcrumb:Link>
            </twig:Breadcrumb:Item>
            <twig:Breadcrumb:Separator />
            <twig:Breadcrumb:Item>
                <twig:Breadcrumb:Link href="{{ path('app_sync_list_history', { id: sync_list.id }) }}">{{ sync_list.name }}</twig:Breadcrumb:Link>
            </twig:Breadcrumb:Item>
            <twig:Breadcrumb:Separator />
            <twig:Breadcrumb:Item>
                <twig:Breadcrumb:Page>Contacts</twig:Breadcrumb:Page>
            </twig:Breadcrumb:Item>
        </twig:Breadcrumb:List>
    </twig:Breadcrumb>
    <div class="mt-4">
        <h1 class="text-2xl font-bold text-foreground">Contacts</h1>
        <p class="mt-1 text-sm text-muted-foreground">
            {{ source_contacts|length }} source contacts{% if manual_contacts|length > 0 %}, {{ manual_contacts|length }} manual contacts{% endif %}
            for <strong>{{ sync_list.name }}</strong>
        </p>
    </div>
</div>

{% set all_contacts = [] %}
{% for contact in source_contacts %}
    {% set all_contacts = all_contacts|merge([{ name: contact.name, email: contact.email, source: 'Source' }]) %}
{% endfor %}
{% for contact in manual_contacts %}
    {% set all_contacts = all_contacts|merge([{ name: contact.name, email: contact.email, source: 'Manual' }]) %}
{% endfor %}

{% if all_contacts|length > 0 %}
    <twig:Card>
        <twig:Table>
            <twig:Table:Header>
                <twig:Table:Row>
                    <twig:Table:Head>Name</twig:Table:Head>
                    <twig:Table:Head>Email</twig:Table:Head>
                    <twig:Table:Head>Source</twig:Table:Head>
                </twig:Table:Row>
            </twig:Table:Header>
            <twig:Table:Body>
                {% for contact in all_contacts|sort((a, b) => a.name <=> b.name) %}
                    <twig:Table:Row>
                        <twig:Table:Cell class="font-medium">{{ contact.name }}</twig:Table:Cell>
                        <twig:Table:Cell>{{ contact.email }}</twig:Table:Cell>
                        <twig:Table:Cell>
                            {% if contact.source == 'Manual' %}
                                <twig:Badge variant="secondary">Manual</twig:Badge>
                            {% else %}
                                <twig:Badge variant="outline">Source</twig:Badge>
                            {% endif %}
                        </twig:Table:Cell>
                    </twig:Table:Row>
                {% endfor %}
            </twig:Table:Body>
        </twig:Table>
    </twig:Card>
{% else %}
    <div class="rounded-lg border-2 border-dashed border-border p-12 text-center">
        <twig:ux:icon name="lucide:users" class="mx-auto h-12 w-12 text-muted-foreground" />
        <h3 class="mt-2 text-sm font-semibold text-foreground">No contacts yet</h3>
        <p class="mt-1 text-sm text-muted-foreground">Contacts will appear here after a successful sync run.</p>
    </div>
{% endif %}
{% endblock %}
