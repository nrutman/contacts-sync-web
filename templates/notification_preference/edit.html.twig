{% extends 'base.html.twig' %}

{% block title %}Notification Preferences — Contacts Sync{% endblock %}

{% block body %}
<div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Notification Preferences</h1>
    <p class="mt-1 text-sm text-gray-500">Choose when you want to receive email notifications about sync runs.</p>
</div>

<div class="max-w-2xl">
    <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            {{ form_start(form, { attr: { class: 'space-y-6' } }) }}

            <fieldset>
                <legend class="text-base font-semibold text-gray-900">Email Notifications</legend>
                <p class="mt-1 text-sm text-gray-500">Notifications are sent after each sync run completes, based on the preferences below.</p>

                <div class="mt-6 space-y-5">
                    <div class="relative flex items-start">
                        <div class="flex h-6 items-center">
                            {{ form_widget(form.notifyOnSuccess, { attr: { class: 'h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600' } }) }}
                        </div>
                        <div class="ml-3">
                            {{ form_label(form.notifyOnSuccess, null, { label_attr: { class: 'text-sm font-medium text-gray-900' } }) }}
                            {% if form.notifyOnSuccess.vars.help %}
                                <p class="mt-0.5 text-sm text-gray-500">{{ form.notifyOnSuccess.vars.help }}</p>
                            {% endif %}
                            {{ form_errors(form.notifyOnSuccess) }}
                        </div>
                    </div>

                    <div class="relative flex items-start">
                        <div class="flex h-6 items-center">
                            {{ form_widget(form.notifyOnFailure, { attr: { class: 'h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600' } }) }}
                        </div>
                        <div class="ml-3">
                            {{ form_label(form.notifyOnFailure, null, { label_attr: { class: 'text-sm font-medium text-gray-900' } }) }}
                            {% if form.notifyOnFailure.vars.help %}
                                <p class="mt-0.5 text-sm text-gray-500">{{ form.notifyOnFailure.vars.help }}</p>
                            {% endif %}
                            {{ form_errors(form.notifyOnFailure) }}
                        </div>
                    </div>

                    <div class="relative flex items-start">
                        <div class="flex h-6 items-center">
                            {{ form_widget(form.notifyOnNoChanges, { attr: { class: 'h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600' } }) }}
                        </div>
                        <div class="ml-3">
                            {{ form_label(form.notifyOnNoChanges, null, { label_attr: { class: 'text-sm font-medium text-gray-900' } }) }}
                            {% if form.notifyOnNoChanges.vars.help %}
                                <p class="mt-0.5 text-sm text-gray-500">{{ form.notifyOnNoChanges.vars.help }}</p>
                            {% endif %}
                            {{ form_errors(form.notifyOnNoChanges) }}
                        </div>
                    </div>
                </div>
            </fieldset>

            <div class="flex items-center justify-end gap-x-3 border-t border-gray-200 pt-6">
                <a href="{{ path('app_dashboard') }}"
                   class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors">
                    Cancel
                </a>
                <button type="submit"
                        class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors">
                    Save Preferences
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

    <div class="mt-6 rounded-md bg-blue-50 border border-blue-200 p-4">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
                </svg>
            </div>
            <div class="ml-3">
                <p class="text-sm text-blue-700">
                    Notifications are sent after each sync run — whether triggered manually, by schedule, or via CLI.
                    If all preferences are unchecked, you will not receive any sync notification emails.
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
