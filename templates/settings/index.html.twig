{% extends 'base.html.twig' %}

{% block title %}Settings — Contacts Sync{% endblock %}

{% block body %}
<div class="mb-8">
    <h1 class="text-2xl font-bold text-foreground">Settings</h1>
    <p class="mt-1 text-sm text-muted-foreground">Manage your organization name and provider credentials.</p>
</div>

{# Organization Settings Form #}
<div class="max-w-3xl">
    <twig:Card>
        <twig:Card:Header>
            <twig:Card:Title>
                {% if is_edit %}
                    Organization Settings
                {% else %}
                    Initial Setup
                {% endif %}
            </twig:Card:Title>
            <twig:Card:Description>
                {% if is_edit %}
                    Update your organization name.
                {% else %}
                    Set your organization name to get started.
                {% endif %}
            </twig:Card:Description>
        </twig:Card:Header>
        <twig:Card:Content>
            {{ form_start(form, { attr: { class: 'space-y-6', novalidate: 'novalidate' } }) }}

                {{ form_row(form.name) }}

                {% if is_edit %}
                <twig:Separator />
                <div class="space-y-4">
                    <div>
                        <h3 class="text-base font-semibold text-foreground">Retention Policy</h3>
                        <p class="mt-1 text-sm text-muted-foreground">Automatically delete sync history older than the configured period after each sync completes.</p>
                    </div>

                    <div data-controller="retention-picker">
                        <twig:Field>
                            <twig:Field:Label>Keep history for</twig:Field:Label>
                            <twig:Field:Content>
                                <twig:Select data-retention-picker-target="preset" data-action="retention-picker#presetChanged">
                                    <option value="">Forever</option>
                                    <option value="30">30 days</option>
                                    <option value="365">1 year</option>
                                    <option value="custom">Custom</option>
                                </twig:Select>
                            </twig:Field:Content>
                        </twig:Field>

                        <div data-retention-picker-target="customField" class="mt-3">
                            {{ form_row(form.retentionDays) }}
                        </div>
                    </div>
                </div>
                {% endif %}

                <twig:Separator />
                <div class="flex items-center justify-end gap-x-4">
                    {% if is_edit %}
                        <twig:Button as="a" href="{{ path('app_dashboard') }}" variant="outline">Cancel</twig:Button>
                    {% endif %}
                    <twig:Button type="submit">
                        {% if is_edit %}
                            Save Settings
                        {% else %}
                            Complete Setup
                        {% endif %}
                    </twig:Button>
                </div>

            {{ form_end(form) }}
        </twig:Card:Content>
    </twig:Card>
</div>

{# Provider Credentials Section #}
{% if is_edit %}
<div class="max-w-3xl mt-8">
    <twig:Card>
        <twig:Card:Header>
            <div class="flex items-center justify-between">
                <div>
                    <twig:Card:Title>Provider Credentials</twig:Card:Title>
                    <twig:Card:Description>Manage API credentials for sync sources and destinations.</twig:Card:Description>
                </div>
                <twig:Button as="a" href="{{ path('app_credentials_index') }}">
                    Manage Credentials
                </twig:Button>
            </div>
        </twig:Card:Header>
        <twig:Card:Content>
            {% if credentials|length > 0 %}
                <div class="divide-y divide-border">
                    {% for credential in credentials %}
                        <div class="py-3 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="text-sm font-medium text-foreground">{{ credential.displayLabel }}</span>
                                <twig:Badge variant="secondary">{{ credential.providerName }}</twig:Badge>
                            </div>
                            <span class="text-xs text-muted-foreground"
                                  data-controller="timezone"
                                  data-timezone-datetime-value="{{ credential.createdAt|date('c') }}"
                                  data-timezone-format-value="date"
                                  title="{{ credential.createdAt|date('Y-m-d H:i:s T') }}">
                                Added {{ credential.createdAt|date('M j, Y') }}
                            </span>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-sm text-muted-foreground">No credentials configured yet. <a href="{{ path('app_credentials_index') }}" class="text-primary hover:underline">Add one</a> to get started.</p>
            {% endif %}
        </twig:Card:Content>
    </twig:Card>
</div>
{% endif %}

{# Encryption Notice #}
<div class="max-w-3xl mt-8">
    <twig:Alert>
        <twig:ux:icon name="lucide:lock" class="size-4" />
        <twig:Alert:Title>Encryption</twig:Alert:Title>
        <twig:Alert:Description>
            API credentials and secrets are encrypted at rest using authenticated encryption (XSalsa20-Poly1305).
        </twig:Alert:Description>
    </twig:Alert>
</div>
{% endblock %}
