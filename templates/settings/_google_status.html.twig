<turbo-frame id="google-status">
    <div class="rounded-lg border p-4 {{ google_connected ? 'border-green-200 bg-green-50' : (google_error ? 'border-red-200 bg-red-50' : 'border-gray-200 bg-gray-50') }}">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                {% if google_connected %}
                    <div class="flex-shrink-0">
                        <svg class="h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-green-800">Google Account Connected</h4>
                        <p class="text-sm text-green-700">Your Google Workspace account is connected and ready to sync.</p>
                    </div>
                {% elseif google_error %}
                    <div class="flex-shrink-0">
                        <svg class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-red-800">Google Connection Error</h4>
                        <p class="text-sm text-red-700">{{ google_error }}</p>
                    </div>
                {% else %}
                    <div class="flex-shrink-0">
                        <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                        </svg>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-gray-800">Google Account Not Connected</h4>
                        <p class="text-sm text-gray-600">Connect your Google Workspace account to enable contact syncing.</p>
                    </div>
                {% endif %}
            </div>

            <div class="flex-shrink-0 ml-4">
                {% if google_connected %}
                    <form action="{{ path('app_settings_google_disconnect') }}" method="post" class="inline"
                          data-controller="confirm"
                          data-confirm-message-value="Are you sure you want to disconnect your Google account? Syncing will stop working until you reconnect.">
                        <input type="hidden" name="_token" value="{{ csrf_token('google-disconnect') }}">
                        <button type="submit"
                                class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors">
                            Disconnect
                        </button>
                    </form>
                {% elseif organization %}
                    <a href="{{ path('app_settings_google_connect') }}"
                       class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors">
                        <svg class="-ml-0.5 mr-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                        </svg>
                        Connect Google Account
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</turbo-frame>
