#!/usr/bin/env bash
# Auto-run the prod deploy after a merge (which includes `git pull`).
# Silent no-op on non-prod environments.
#
# This hook lives in .githooks/ (not .git/hooks/) because the project
# sets `core.hooksPath = .githooks` via `composer setup-hooks`. Git
# ignores .git/hooks/ when core.hooksPath is set.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Resolve APP_ENV from the shell or .env.local (matches scripts/deploy.sh).
if [ -z "${APP_ENV:-}" ] && [ -f .env.local ]; then
    APP_ENV=$(grep -E '^\s*APP_ENV\s*=' .env.local | tail -1 \
        | sed -E "s/^\s*APP_ENV\s*=\s*//; s/^[\"']//; s/[\"']$//")
fi

[ "${APP_ENV:-}" = "prod" ] || exit 0

exec ./scripts/deploy.sh
